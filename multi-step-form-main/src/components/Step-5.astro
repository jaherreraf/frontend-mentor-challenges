---
import thankYouIcon from '../assets/images/icon-thank-you.svg';
---
<div class="step-5 w-full py-10 md:py-16">
  <div class="flex flex-col items-center text-center gap-4 max-w-md mx-auto">
    <img src={thankYouIcon.src} alt="Thank You Icon" class="w-14 h-14 md:w-20 md:h-20" />
    <h2 class="text-3xl font-bold text-marine-blue">Thank you!</h2>
    <p class="text-cool-gray leading-relaxed text-sm md:text-base">
      Thanks for confirming your subscription! We hope you have fun using our platform. If you ever need support, please feel free to email us at support@loremgaming.com.
    </p>
  </div>
</div>